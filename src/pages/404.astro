---
import Cursor from '../components/Cursor.astro'
import { getLangFromUrl, useTranslations } from '../i18n/utils'
import '../styles/global.css'

// Local Fonts
import '@fontsource-variable/inter'
import '@fontsource-variable/newsreader'
import '@fontsource/material-symbols-outlined'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const isEs = lang === 'es'
const title = isEs ? '404 | Página No Encontrada' : '404 | Page Not Found'
const description = isEs
	? 'La página que buscas no existe.'
	: 'The page you are looking for does not exist.'
---

<!doctype html>
<html class="dark" lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/logo.svg?v=1" />
	</head>
	<body class="antialiased overflow-hidden bg-surface">
		<Cursor />
		<div class="noise-overlay fixed inset-0 pointer-events-none z-[9999] opacity-[0.03] mix-blend-overlay bg-[url('https://grainy-gradients.vercel.app/noise.svg')]"></div>

		<main class="h-screen w-screen flex items-center justify-center px-8 relative surface-texture">
			<!-- Background Elements -->
			<div class="absolute inset-0 opacity-[0.05] bg-[url('https://grainy-gradients.vercel.app/noise.svg')] pointer-events-none z-0"></div>
			<div class="absolute top-0 left-1/2 w-[1px] h-full bg-gradient-to-b from-transparent via-white/5 to-transparent pointer-events-none"></div>
			
			<div class="max-w-4xl w-full text-center relative z-10">
				<span class="text-primary uppercase tracking-[0.4em] text-[10px] mb-8 block font-semibold">
					Error 404 // Void Detected
				</span>
				
				<h1 class="serif-display text-[12rem] md:text-[18rem] leading-[0.8] text-on-surface opacity-5 mb-0 select-none italic font-light">
					404
				</h1>
				
				<div class="relative -mt-24 md:-mt-40">
					<h2 class="serif-display text-4xl md:text-6xl text-on-surface mb-8 tracking-tighter italic">
						{isEs ? "Página no encontrada." : "Page not found."}
					</h2>
					
					<p class="text-on-surface-variant max-w-md mx-auto mb-12 font-light leading-relaxed">
						{isEs 
							? "Has navegado fuera de los límites de este sitio. El recurso solicitado no existe o ha sido reubicado." 
							: "You have navigated beyond the boundaries of this site. The requested resource does not exist or has been relocated."}
					</p>
					
					<div class="flex flex-col sm:flex-row items-center justify-center gap-8">
						<a
							href={isEs ? "/es" : "/"}
							class="group flex items-center gap-4 text-primary tracking-widest uppercase text-xs font-semibold hover:text-white transition-colors duration-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface"
						>
							<span class="h-[1px] w-12 bg-primary/40 transition-all duration-500 group-hover:w-20 group-hover:bg-white"></span>
							{isEs ? "Volver al Inicio" : "Return to Home"}
						</a>
					</div>
				</div>
			</div>

			<!-- Subtle Light Leak -->
			<div class="absolute -bottom-1/4 -left-1/4 w-[600px] h-[600px] bg-gradient-to-tr from-primary/5 to-transparent rounded-full blur-[120px] pointer-events-none"></div>
		</main>
	</body>
</html>

<style>
	h1 {
		filter: drop-shadow(0 0 100px rgba(var(--primary-rgb), 0.1));
	}
	body {
		/* Disable dynamic typography vars for this page */
		--scroll-progress: 0 !important;
	}
</style>
