---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface SkillItem {
	name: string
	number: string
}

interface SkillColumn {
	title: string
	items: SkillItem[]
}

const columns: SkillColumn[] = [
	{
		title: t('skills.col1'),
		items: [
			{ name: 'React 19 & Next.js', number: '01' },
			{ name: 'Astro & TypeScript', number: '02' },
			{ name: 'Tailwind CSS 4', number: '03' },
			{ name: 'State Management & Signals', number: '04' },
		],
	},
	{
		title: t('skills.col2'),
		items: [
			{ name: 'Bun / Node.js', number: '05' },
			{ name: 'PostgreSQL & Supabase', number: '06' },
			{ name: 'WebSockets & Real-time', number: '07' },
			{ name: 'Clean Architecture', number: '08' },
		],
	},
	{
		title: t('skills.col3'),
		items: [
			{ name: 'CI/CD & DevOps', number: '09' },
			{ name: 'Performance Optimization', number: '10' },
			{ name: 'Zod & Schema Validation', number: '11' },
			{ name: 'AI Integration', number: '12' },
		],
	},
]
---

<section class="py-32 px-8 bg-surface reveal" id="skills">
	<div class="max-w-7xl mx-auto">
		<!-- Header -->
		<div class="flex flex-col md:flex-row justify-between items-end mb-24 gap-8">
			<div class="max-w-2xl">
				<span class="text-[10px] uppercase tracking-[0.4em] text-primary"
					>{t('skills.title')}</span
				>
				<h2 class="serif-display text-6xl mt-4 text-on-surface">{t('skills.subtitle')}</h2>
			</div>
			<p
				class="text-on-surface-variant max-w-xs text-right hidden md:block italic font-light"
			>
				{t('skills.description')}
			</p>
		</div>

		<!-- Skills Grid -->
		<div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-white/5">
			{
				columns.map((column, colIdx) => (
					<div
						class:list={[
							'bg-surface p-12 space-y-8 transition-premium hover:bg-surface-container-low group',
						]}
					>
						<h3 class="serif-display text-2xl italic text-primary">
							{column.title}
						</h3>
						<ul class="space-y-4 text-on-surface-variant font-body">
							{column.items.map((item) => (
								<li class="flex justify-between items-center group/item">
									<span class="group-hover/item:text-on-surface transition-colors duration-500">
										{item.name}
									</span>
									<span class="text-[10px] opacity-40 group-hover/item:opacity-100 group-hover/item:text-primary transition-opacity duration-500">
										{item.number}
									</span>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>
	</div>
</section>
