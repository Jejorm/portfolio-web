---
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<section class="min-h-screen flex flex-col justify-center px-8 relative overflow-hidden bg-surface surface-texture" aria-labelledby="hero-heading">
	<!-- Noise Gradient Overlay -->
	<div class="absolute inset-0 opacity-[0.05] bg-[url('https://grainy-gradients.vercel.app/noise.svg')] pointer-events-none z-0" aria-hidden="true"></div>
	
	<div class="max-w-7xl mx-auto w-full pt-32 pb-20 relative z-10">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24 items-start">
			<div class="lg:col-span-8 reveal active">
				<p class="text-primary tracking-[0.4em] uppercase text-[10px] font-semibold mb-10 flex items-center gap-6" aria-label="Professional focus">
					<span class="w-12 h-[1px] bg-primary/40" aria-hidden="true"></span>
					{t('hero.focus')}
				</p>
				<h1 id="hero-heading" class="serif-display text-on-surface mb-0 text-7xl lg:text-[10rem] leading-[0.85]">
					{t('hero.title1')} <br />
					<span class="italic text-primary">{t('hero.title2')}</span>
					<br />
					{t('hero.title3')}
				</h1>
			</div>
			<div
				class="lg:col-span-4 pt-12 lg:pt-32 reveal active"
				style="transition-delay: 200ms;"
			>
				<div class="relative group">
					<!-- Technical Container -->
					<div class="bg-surface-container-low p-8 border border-white/5 relative overflow-hidden transition-premium hover:border-primary/20 group-hover:shadow-[0_20px_50px_rgba(0,0,0,0.3)]">
						<!-- Scanner Effect -->
						<div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>

						<!-- Precision Marks -->
						<div class="absolute top-0 left-0 w-2 h-2 border-t border-l border-primary/40 opacity-50"></div>
						<div class="absolute top-0 right-0 w-2 h-2 border-t border-r border-primary/40 opacity-50"></div>
						<div class="absolute bottom-0 left-0 w-2 h-2 border-b border-l border-primary/40 opacity-50"></div>
						<div class="absolute bottom-0 right-0 w-2 h-2 border-b border-r border-primary/40 opacity-50"></div>

						<!-- Brief Label & Coordinates -->
						<div class="flex items-center justify-between mb-8">
							<div class="flex items-center gap-3">
								<span class="text-[8px] tracking-[0.5em] uppercase text-primary font-bold">Brief / 001</span>
								<div class="h-[1px] w-12 bg-gradient-to-r from-primary/30 to-transparent"></div>
							</div>
							<span class="text-[7px] font-mono text-on-surface-variant/40 tracking-tighter">40.7128° N, 74.0060° W</span>
						</div>

						<p class="text-on-surface-variant font-body text-base lg:text-lg leading-relaxed mb-10 font-light relative z-10">
							{t('hero.description')}
						</p>

						<div class="flex items-center gap-4 pt-6 border-t border-white/5 relative z-10">
							<a
								class="group/cta flex items-center gap-4 text-on-surface tracking-widest uppercase text-[10px] font-semibold hover:text-primary transition-colors duration-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface"
								href="#projects"
								aria-label="Navigate to selected projects archive"
							>
								{t('hero.cta')}
								<span
									class="h-[1px] w-8 bg-on-surface-variant transition-all duration-500 group-hover/cta:w-16 group-hover/cta:bg-primary"
								></span>
							</a>
						</div>
					</div>

					<!-- Floating Technical Detail -->
					<div class="absolute -bottom-6 -right-4 bg-surface px-3 py-1 border border-white/10 hidden xl:block pointer-events-none opacity-40">
						<span class="text-[7px] tracking-widest uppercase text-on-surface-variant">V.6.1.1 // SYSTEM_STABLE</span>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Architectural Light / Void Elements -->
	<div
		class="absolute -bottom-1/4 -right-1/4 w-[800px] h-[800px] bg-gradient-to-br from-primary/5 to-transparent rounded-full blur-[120px] pointer-events-none"
	>
	</div>
	<div class="absolute top-0 left-1/4 w-[1px] h-full bg-gradient-to-b from-transparent via-white/5 to-transparent pointer-events-none"></div>
	<div class="absolute top-0 left-2/4 w-[1px] h-full bg-gradient-to-b from-transparent via-white/5 to-transparent pointer-events-none"></div>
</section>
