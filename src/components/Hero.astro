---

---

<section class="min-h-screen flex flex-col justify-center px-8 relative overflow-hidden bg-surface" aria-label="Introduction">
	<div class="max-w-7xl mx-auto w-full pt-20 relative z-10">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-end">
			<div class="lg:col-span-8 reveal active">
				<p class="text-primary tracking-[0.3em] uppercase text-xs font-medium mb-8 flex items-center gap-4">
					<span class="w-8 h-[1px] bg-primary"></span>
					Full-Stack Web Developer
				</p>
				<h1
					class="serif-display text-7xl md:text-9xl leading-[0.9] tracking-tighter mb-12 text-on-surface"
				>
					Engineering <br />
					<span class="italic text-primary">scalable systems</span>
					<br />
					& precise UI.
				</h1>
			</div>
			<div
				class="lg:col-span-4 pb-4 reveal active"
				style="transition-delay: 200ms;"
			>
				<p
					class="text-on-surface-variant font-body text-lg max-w-sm mb-8 leading-relaxed font-light"
				>
					I architect and build high-performance web applications using <strong class="font-medium text-on-surface">React 19, Next.js, and modern runtimes like Bun</strong>. My focus is on structural integrity, speed, and uncompromising aesthetic reduction.
				</p>
				<a
					class="group flex items-center gap-4 text-on-surface tracking-widest uppercase text-xs font-semibold hover:text-primary transition-colors duration-500 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface"
					href="#projects"
					aria-label="Scroll down to view selected projects"
				>
					View Archive
					<span
						class="h-[1px] w-12 bg-on-surface-variant transition-all duration-500 group-hover:w-20 group-hover:bg-primary"
					></span>
				</a>
			</div>
		</div>
	</div>

	<!-- Architectural Light / Void Elements -->
	<div
		class="absolute -bottom-1/4 -right-1/4 w-[800px] h-[800px] bg-gradient-to-br from-primary/5 to-transparent rounded-full blur-[120px] pointer-events-none"
	>
	</div>
	<div class="absolute top-0 left-1/4 w-[1px] h-full bg-gradient-to-b from-transparent via-white/5 to-transparent pointer-events-none"></div>
	<div class="absolute top-0 left-2/4 w-[1px] h-full bg-gradient-to-b from-transparent via-white/5 to-transparent pointer-events-none"></div>
</section>
