---
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<section class="min-h-screen flex flex-col justify-center px-8 relative overflow-hidden bg-surface surface-texture" aria-labelledby="hero-heading">
	<!-- Noise Gradient Overlay -->
	<div class="absolute inset-0 opacity-[0.05] bg-[url('https://grainy-gradients.vercel.app/noise.svg')] pointer-events-none z-0" aria-hidden="true"></div>
	
	<div class="max-w-7xl mx-auto w-full pt-32 pb-20 relative z-10">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24 items-start">
			<div class="lg:col-span-8 reveal active">
				<p class="text-primary tracking-[0.4em] uppercase text-[10px] font-semibold mb-10 flex items-center gap-6" aria-label="Professional focus">
					<span class="w-12 h-[1px] bg-primary/40" aria-hidden="true"></span>
					{t('hero.focus')}
				</p>
				<h1 id="hero-heading" class="serif-display text-on-surface mb-0 text-7xl lg:text-[10rem] leading-[0.85]">
					{t('hero.title1')} <br />
					<span class="italic text-primary">{t('hero.title2')}</span>
					<br />
					{t('hero.title3')}
				</h1>
			</div>
			<div
				class="lg:col-span-4 pt-12 lg:pt-32 reveal active"
				style="transition-delay: 200ms;"
			>
				<p class="text-on-surface-variant font-body lead-text mb-12 font-light border-l border-primary/20 pl-8 py-4">
					{t('hero.description')}
				</p>
				<div class="pl-8">
					<a
						class="group flex items-center gap-4 text-on-surface tracking-widest uppercase text-xs font-semibold hover:text-primary transition-colors duration-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface"
						href="#projects"
						aria-label="Navigate to selected projects archive"
					>
						{t('hero.cta')}
						<span
							class="h-[1px] w-12 bg-on-surface-variant transition-all duration-500 group-hover:w-20 group-hover:bg-primary"
						></span>
					</a>
				</div>
			</div>
		</div>
	</div>

	<!-- Architectural Light / Void Elements -->
	<div
		class="absolute -bottom-1/4 -right-1/4 w-[800px] h-[800px] bg-gradient-to-br from-primary/5 to-transparent rounded-full blur-[120px] pointer-events-none"
	>
	</div>
	<div class="absolute top-0 left-1/4 w-[1px] h-full bg-gradient-to-b from-transparent via-white/5 to-transparent pointer-events-none"></div>
	<div class="absolute top-0 left-2/4 w-[1px] h-full bg-gradient-to-b from-transparent via-white/5 to-transparent pointer-events-none"></div>
</section>
