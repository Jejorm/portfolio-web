---
import { Image } from 'astro:assets'
import heroImg from '../assets/images/hero-image.png'
---

<section class="min-h-screen flex flex-col justify-center px-8 relative overflow-hidden bg-surface surface-texture" aria-label="Introduction">
	<!-- Noise Gradient Overlay -->
	<div class="absolute inset-0 opacity-[0.05] bg-[url('https://grainy-gradients.vercel.app/noise.svg')] pointer-events-none z-0"></div>
	
	<div class="max-w-7xl mx-auto w-full pt-32 pb-20 relative z-10">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
			<div class="lg:col-span-7 reveal active">
				<p class="text-primary tracking-[0.4em] uppercase text-[10px] font-semibold mb-10 flex items-center gap-6">
					<span class="w-12 h-[1px] bg-primary/40"></span>
					Full-Stack Architecture & Engineering
				</p>
				<h1 class="serif-display text-on-surface mb-0">
					Engineering <br />
					<span class="italic text-primary">scalable systems</span>
					<br />
					& precise UI.
				</h1>
			</div>
			<div
				class="lg:col-span-5 pb-4 reveal active"
				style="transition-delay: 200ms;"
			>
				<div class="relative group mb-16">
					<div
						class="aspect-[3/4] bg-surface-container overflow-hidden shadow-2xl transition-premium group-hover:shadow-primary/5 rounded-[2px]"
					>
						<Image
							alt="Portrait of the developer"
							class="w-full h-full object-cover grayscale brightness-90 contrast-110 transition-transform-colors duration-1000 ease-[cubic-bezier(0.23,1,0.32,1)] group-hover:scale-[1.05] group-hover:grayscale-0 group-hover:brightness-100 group-hover:contrast-100"
							src={heroImg}
							widths={[400, 800]}
							sizes="(max-width: 768px) 100vw, 33vw"
							loading="eager"
							decoding="async"
						/>
					</div>
				</div>
				<p class="text-on-surface-variant font-body lead-text max-w-sm mb-12 font-light">
					I architect and build high-performance web applications using <strong class="font-medium text-on-surface">React 19, Next.js, and modern runtimes like Bun</strong>. Focus on structural integrity and aesthetic reduction.
				</p>
				<a
					class="group flex items-center gap-4 text-on-surface tracking-widest uppercase text-xs font-semibold hover:text-primary transition-colors duration-500 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface"
					href="#projects"
					aria-label="Scroll down to view selected projects"
				>
					View Archive
					<span
						class="h-[1px] w-12 bg-on-surface-variant transition-all duration-500 group-hover:w-20 group-hover:bg-primary"
					></span>
				</a>
			</div>
		</div>
	</div>

	<!-- Architectural Light / Void Elements -->
	<div
		class="absolute -bottom-1/4 -right-1/4 w-[800px] h-[800px] bg-gradient-to-br from-primary/5 to-transparent rounded-full blur-[120px] pointer-events-none"
	>
	</div>
	<div class="absolute top-0 left-1/4 w-[1px] h-full bg-gradient-to-b from-transparent via-white/5 to-transparent pointer-events-none"></div>
	<div class="absolute top-0 left-2/4 w-[1px] h-full bg-gradient-to-b from-transparent via-white/5 to-transparent pointer-events-none"></div>
</section>
