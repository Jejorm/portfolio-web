---

---

<section class="min-h-screen flex flex-col justify-center px-8 relative overflow-hidden">
	<div class="max-w-7xl mx-auto w-full pt-20">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-end">
			<div class="lg:col-span-8 reveal active">
				<h1
					class="serif-display text-7xl md:text-9xl leading-[0.9] tracking-tighter mb-12"
				>
					Designing <br />
					<span class="italic text-accent-blue">digital structures</span>
					<br />
					with intent.
				</h1>
			</div>
			<div
				class="lg:col-span-4 pb-4 reveal active"
				style="transition-delay: 200ms;"
			>
				<p
					class="text-on-surface-variant font-body text-lg max-w-xs mb-8 leading-relaxed"
				>
					Full-stack developer focused on the intersection of technical
					precision and aesthetic reduction.
				</p>
				<a
					class="group flex items-center gap-4 text-accent-blue tracking-widest uppercase text-xs font-semibold hover:text-white transition-colors duration-500"
					href="#projects"
				>
					View Works
					<span
						class="h-px w-12 bg-accent-blue transition-all duration-500 group-hover:w-20 group-hover:bg-white"
					></span>
				</a>
			</div>
		</div>
	</div>

	<!-- Ambient Light Elements -->
	<div
		class="absolute -bottom-1/4 -right-1/4 w-[600px] h-[600px] bg-accent-blue/10 rounded-full blur-[120px] pointer-events-none"
	>
	</div>
	<div
		class="absolute -top-1/4 -left-1/4 w-[400px] h-[400px] bg-accent-blue/5 rounded-full blur-[100px] pointer-events-none"
	>
	</div>
</section>
