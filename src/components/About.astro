---

---

<section class="py-32 px-8 bg-surface-container-low reveal" id="about">
	<div class="max-w-7xl mx-auto">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
			<!-- Profile Image -->
			<div class="relative group">
				<div
					class="aspect-[4/5] bg-surface-container overflow-hidden shadow-2xl transition-premium group-hover:shadow-accent-blue/5"
				>
					<img
						alt="Professional portrait of a developer in a dark turtleneck"
						class="w-full h-full object-cover grayscale brightness-75 transition-transform duration-1000 ease-out group-hover:scale-105"
						src="/images/profile.png"
					/>
				</div>
				<!-- Floating Location Card -->
				<div
					class="absolute -bottom-8 -right-8 w-48 h-48 bg-accent-blue/10 backdrop-blur-3xl p-6 hidden md:block border border-accent-blue/20 transition-premium group-hover:-translate-x-2 group-hover:-translate-y-2"
				>
					<p class="text-[10px] uppercase tracking-[0.3em] text-accent-blue mb-2">
						Location
					</p>
					<p class="serif-display text-lg italic">Berlin, Germany</p>
				</div>
			</div>

			<!-- Content -->
			<div class="space-y-12">
				<div class="space-y-4">
					<span class="text-[10px] uppercase tracking-[0.4em] text-accent-blue"
						>Background</span
					>
					<h2 class="serif-display text-5xl leading-tight">
						A synthesis of <span class="text-accent-blue">code</span> and
						spatial logic.
					</h2>
				</div>

				<div
					class="space-y-6 text-on-surface-variant font-body leading-relaxed text-lg"
				>
					<p>
						I approach software development as a form of digital architecture.
						Every line of code serves a structural purpose, and every interface
						is a deliberate space for human interaction.
					</p>
					<p>
						With a decade of experience across the stack, I specialize in
						building systems that are as robust as they are refined. My work is
						defined by what is absent as much as what is present.
					</p>
				</div>

				<!-- Stats -->
				<div class="pt-8 flex gap-12">
					<div>
						<p class="text-3xl serif-display text-accent-blue">12+</p>
						<p
							class="text-[10px] uppercase tracking-widest text-on-surface-variant"
						>
							Global Awards
						</p>
					</div>
					<div>
						<p class="text-3xl serif-display text-accent-blue">150k</p>
						<p
							class="text-[10px] uppercase tracking-widest text-on-surface-variant"
						>
							Lines Refined
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
