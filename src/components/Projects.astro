---
import { Image } from 'astro:assets'
import { getCollection } from 'astro:content'

const rawProjects = await getCollection('projects')
const projects = rawProjects
	.map((p) => p.data)
	.sort((a, b) => a.order - b.order)
---

<section class="py-32 px-8 bg-surface-container-low" id="projects">
	<div class="max-w-7xl mx-auto">
		<!-- Section Header -->
		<div class="mb-32 reveal">
			<span
				class="text-primary uppercase tracking-[0.3em] text-[10px] mb-6 block"
				>Portfolio Archive — {new Date().getFullYear()} Edition</span
			>
			<h2
				class="text-7xl md:text-8xl serif-display italic font-light tracking-tight text-on-surface leading-[0.9]"
			>
				Selected <br />
				<span class="ml-12 md:ml-24 text-primary">Works</span>
			</h2>
			<p
				class="mt-12 text-on-surface-variant max-w-xl text-lg leading-relaxed font-light"
			>
				A curated collection of digital monoliths built with structural
				integrity and performance at the core. Each project represents a unique
				challenge in scale, architecture, and user experience.
			</p>
		</div>

		<!-- Project Gallery -->
		<div class="space-y-48">
			{
				projects.map((project) => (
					<section class="asymmetric-grid group reveal">
						{/* Image Column */}
						<div
							class:list={[
								'col-span-12 lg:col-span-7 overflow-hidden relative shadow-2xl transition-premium group-hover:scale-[1.01] group-hover:shadow-primary/10 rounded-[2px]',
								project.reversed && 'lg:order-2',
							]}
						>
							<div class="relative h-full min-h-[300px] lg:min-h-[450px] bg-surface-container overflow-hidden group-hover:after:opacity-0 after:transition-opacity after:duration-700 after:absolute after:inset-0 after:bg-black/20 after:pointer-events-none">
								{/* Noise/Grain Overlay */}
								<div class="absolute inset-0 opacity-[0.03] pointer-events-none z-10 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] mix-blend-overlay"></div>
								
								{/* Image */}
								<Image
									src={project.image}
									alt={project.imageAlt}
									widths={[720, 1280, 1920]}
									sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 1280px"
									quality="high"
									class="w-full h-full object-cover object-center scale-[1.20] grayscale brightness-[0.85] contrast-[1.1] opacity-90 group-hover:opacity-100 group-hover:grayscale-0 group-hover:brightness-100 group-hover:contrast-100 group-hover:scale-[1.25] transition-all duration-1000 ease-[cubic-bezier(0.23,1,0.32,1)]"
								/>
								
								{/* Vignette Overlay */}
								<div class="absolute inset-0 shadow-[inset_0_0_150px_rgba(0,0,0,0.5)] pointer-events-none z-20"></div>
							</div>
						</div>

						{/* Content Column */}
						<div
							class:list={[
								'col-span-12 lg:col-span-5 flex flex-col justify-center',
								project.reversed
									? 'lg:order-1 lg:pr-12 transition-premium group-hover:-translate-x-2'
									: 'lg:pl-12 transition-premium group-hover:translate-x-2',
							]}
						>
							<span class="text-primary serif-display italic text-2xl mb-4">
								{project.number}
							</span>
							<h3 class="text-5xl serif-display tracking-tighter mb-8">
								{project.title}
							</h3>

							{/* Quote Block */}
							<div
								class:list={[
									'bg-surface-container-lowest border-l-2 p-8 mb-8 transition-premium group-hover:bg-black',
									project.reversed
										? 'border-primary/60 group-hover:border-primary'
										: 'border-primary group-hover:border-white',
								]}
							>
								<p class="text-on-surface-variant font-light leading-relaxed italic">
									{project.quote}
								</p>
							</div>

							{/* Tags */}
							<div class="flex flex-wrap gap-3 mb-10">
								{
									project.tags.map((tag) => (
										<span class="flex items-center gap-2 px-4 py-1.5 text-[10px] uppercase tracking-widest border border-white/10 text-on-surface-variant bg-surface-container transition-all duration-300 hover:bg-white hover:text-black hover:border-white hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,255,255,0.15)] group/tag cursor-default">
											<img
												src={`https://cdn.simpleicons.org/${tag.icon}/white`}
												alt=""
												class="w-3 h-3 opacity-50 group-hover/tag:hidden"
											/>
											<img
												src={`https://cdn.simpleicons.org/${tag.icon}/black`}
												alt=""
												class="w-3 h-3 hidden group-hover/tag:block"
											/>
											{tag.label}
										</span>
									))
								}
							</div>

							{/* Links */}
							<div class="flex items-center gap-8">
								<a
									class="group/link flex items-center gap-2 text-sm tracking-widest uppercase text-on-surface hover:text-primary transition-colors duration-500"
									href={project.liveUrl}
									target="_blank"
									rel="noopener noreferrer"
									aria-label={`View live demo of ${project.title}`}
								>
									Live Demo
									<span class="material-symbols-outlined text-sm group-hover/link:translate-x-2 transition-transform duration-500" aria-hidden="true">
										arrow_forward
									</span>
								</a>
								<div class="flex flex-col sm:flex-row gap-4 sm:gap-8">
									<a
										class="text-sm tracking-widest uppercase text-on-surface-variant hover:text-primary transition-colors duration-500"
										href={project.secondaryUrl}
										target="_blank"
										rel="noopener noreferrer"
										aria-label={`View ${project.secondaryLabel.toLowerCase()} repository for ${project.title}`}
									>
										{project.secondaryLabel}
									</a>
									{
										project.thirdUrl && (
											<a
												class="text-sm tracking-widest uppercase text-on-surface-variant hover:text-primary transition-colors duration-500"
												href={project.thirdUrl}
												target="_blank"
												rel="noopener noreferrer"
												aria-label={`View ${project.thirdLabel?.toLowerCase() || 'secondary source'} repository for ${project.title}`}
											>
												{project.thirdLabel}
											</a>
										)
									}
								</div>
							</div>
						</div>
					</section>
				))
			}
		</div>

		<!-- Archive CTA (Temporarily Disabled) -->
		<!--
		<div class="mt-48 flex justify-center reveal">
			<button class="group flex flex-col items-center">
				<span
					class="text-on-surface-variant uppercase tracking-[0.4em] text-[10px] mb-4 group-hover:text-primary transition-colors duration-500"
					>Explore Archive</span
				>
				<span
					class="material-symbols-outlined text-3xl font-light text-primary animate-bounce"
					>expand_more</span
				>
			</button>
		</div>
		-->
	</div>
</section>
