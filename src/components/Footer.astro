---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();
---

<footer class="bg-surface-container-lowest" aria-label="Site Footer">
	<div
		class="flex flex-col md:flex-row justify-between items-center max-w-7xl mx-auto border-t border-white/5 w-full py-20 px-8"
	>
		<div
			class="font-body text-[10px] uppercase tracking-[0.2em] text-on-surface-variant mb-8 md:mb-0"
		>
			© {currentYear} {t('footer.copyright')}
		</div>
		<div class="flex space-x-10 items-center">
			<a
				class="group transition-all duration-500 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface-container-lowest hover:scale-110"
				href="https://github.com/Jejorm"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Visit my GitHub profile"
			>
				<svg
					viewBox="0 0 24 24"
					class="w-6 h-6 fill-current text-on-surface-variant opacity-50 group-hover:opacity-100 group-hover:text-primary transition-all"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path
						d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.63-.33 2.47-.33c.84 0 1.68.11 2.47.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69 1.02.69 2.06v3.07c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2z"
					></path>
				</svg>
			</a>
			<a
				class="group transition-all duration-500 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface-container-lowest hover:scale-110"
				href="https://www.linkedin.com/in/jeremy-orellana-76224023a/"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Visit my LinkedIn profile"
			>
				<svg
					viewBox="0 0 24 24"
					class="w-6 h-6 fill-current text-on-surface-variant opacity-50 group-hover:opacity-100 group-hover:text-primary transition-all"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path
						d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"
					></path>
				</svg>
			</a>
		</div>
	</div>
</footer>
