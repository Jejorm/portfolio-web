---
const currentYear = new Date().getFullYear();
---

<footer class="bg-surface-container-lowest" aria-label="Site Footer">
	<div
		class="flex flex-col md:flex-row justify-between items-center max-w-7xl mx-auto border-t border-white/5 w-full py-20 px-8"
	>
		<div
			class="font-body text-[10px] uppercase tracking-[0.2em] text-on-surface-variant mb-8 md:mb-0"
		>
			© {currentYear} Architectural Silence.
			<span class="text-primary ml-2">Built with precision.</span>
		</div>
		<div class="flex space-x-12">
			<a
				class="font-body text-[10px] uppercase tracking-[0.2em] text-on-surface-variant hover:text-primary transition-colors duration-500 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface-container-lowest"
				href="https://github.com/Jejorm"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Visit my GitHub profile"
			>Github</a>
			<a
				class="font-body text-[10px] uppercase tracking-[0.2em] text-on-surface-variant hover:text-primary transition-colors duration-500 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface-container-lowest"
				href="https://linkedin.com/in/jejorm"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Visit my LinkedIn profile"
			>LinkedIn</a>
			<a
				class="font-body text-[10px] uppercase tracking-[0.2em] text-on-surface-variant hover:text-primary transition-colors duration-500 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface-container-lowest"
				href="#contact"
				aria-label="Scroll to contact section"
			>Email</a>
		</div>
	</div>
</footer>
