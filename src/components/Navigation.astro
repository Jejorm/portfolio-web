---

---

<nav
	class="fixed top-0 w-full z-50 bg-zinc-900/60 backdrop-blur-xl border-b border-accent-blue/10 transition-all duration-700 ease-in-out"
	id="main-nav"
>
	<div
		class="flex justify-between items-center max-w-7xl mx-auto px-8 py-6 transition-all duration-700"
		id="nav-container"
	>
		<a
			href="#"
			class="text-xl font-medium tracking-tighter text-zinc-100 serif-display"
			>ARCHITECT</a
		>

		<!-- Desktop Nav -->
		<div class="hidden md:flex space-x-12 items-center">
			<a
				class="text-zinc-500 hover:text-accent-blue transition-colors duration-500 serif-display tracking-tight"
				href="#about">About</a
			>
			<a
				class="text-zinc-500 hover:text-accent-blue transition-colors duration-500 serif-display tracking-tight"
				href="#skills">Skills</a
			>
			<a
				class="text-zinc-500 hover:text-accent-blue transition-colors duration-500 serif-display tracking-tight"
				href="#projects">Projects</a
			>
			<a
				class="px-6 py-2 bg-accent-blue text-white font-medium transition-all duration-500 hover:bg-accent-blue-deep active:scale-95"
				href="#contact">Contact</a
			>
		</div>

		<!-- Mobile Hamburger -->
		<button class="md:hidden" id="menu-toggle" aria-label="Toggle navigation menu">
			<span class="material-symbols-outlined text-on-surface text-2xl"
				>menu</span
			>
		</button>
	</div>

	<!-- Mobile Menu -->
	<div class="mobile-menu md:hidden" id="mobile-menu">
		<div class="flex flex-col px-8 pb-6 space-y-4">
			<a
				class="text-zinc-400 hover:text-accent-blue transition-colors duration-500 serif-display tracking-tight text-lg"
				href="#about">About</a
			>
			<a
				class="text-zinc-400 hover:text-accent-blue transition-colors duration-500 serif-display tracking-tight text-lg"
				href="#skills">Skills</a
			>
			<a
				class="text-zinc-400 hover:text-accent-blue transition-colors duration-500 serif-display tracking-tight text-lg"
				href="#projects">Projects</a
			>
			<a
				class="inline-block px-6 py-3 bg-accent-blue text-white font-medium text-center transition-all duration-500 hover:bg-accent-blue-deep"
				href="#contact">Contact</a
			>
		</div>
	</div>
</nav>

<script>
	// Navigation scroll effect
	function initNav() {
		const nav = document.getElementById('main-nav')
		const navContainer = document.getElementById('nav-container')
		const menuToggle = document.getElementById('menu-toggle')
		const mobileMenu = document.getElementById('mobile-menu')

		if (!nav || !navContainer) return

		window.addEventListener('scroll', () => {
			if (window.scrollY > 100) {
				nav.classList.add('scrolled')
				navContainer.classList.remove('py-6')
				navContainer.classList.add('py-4')
			} else {
				nav.classList.remove('scrolled')
				navContainer.classList.remove('py-4')
				navContainer.classList.add('py-6')
			}
		})

		// Mobile menu toggle
		menuToggle?.addEventListener('click', () => {
			mobileMenu?.classList.toggle('open')
			const icon = menuToggle.querySelector('.material-symbols-outlined')
			if (icon) {
				icon.textContent = mobileMenu?.classList.contains('open')
					? 'close'
					: 'menu'
			}
		})

		// Close mobile menu on link click
		mobileMenu?.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => {
				mobileMenu.classList.remove('open')
				const icon = menuToggle?.querySelector('.material-symbols-outlined')
				if (icon) icon.textContent = 'menu'
			})
		})
	}

	// Run on initial load and on view transition
	initNav()
	document.addEventListener('astro:after-swap', initNav)
</script>
