---
import { languages } from '../i18n/ui'
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<nav
	class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-xl border-b border-white/5 transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)]"
	id="main-nav"
	aria-label="Main Navigation"
>
	<div
		class="flex justify-between items-center max-w-7xl mx-auto px-8 py-6 transition-all duration-700"
		id="nav-container"
	>
		<!-- Brand / Logo Container -->
		<a
			href={lang === "en" ? "/" : `/${lang}/`}
			class="logo-container flex items-center gap-3 text-on-surface focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface group"
			aria-label="Go to homepage"
			onclick={`if (window.location.pathname === '${lang === "en" ? "/" : `/${lang}/`}') { window.scrollTo({ top: 0, behavior: 'smooth' }); return false; }`}
		>
			<div
				class="w-10 h-10 relative z-10 transition-transform duration-700 group-hover:scale-110"
			>
				<img src="/logo.svg" alt="Logo" class="w-full h-full drop-shadow-2xl" />
			</div>
			<div
				class="absolute -inset-x-4 -inset-y-2 bg-primary/0 group-hover:bg-primary/5 transition-colors duration-700 rounded-sm -z-10"
			>
			</div>
		</a>

		<!-- Desktop Nav -->
		<div class="hidden md:flex space-x-12 items-center">
			<a
				class="nav-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface"
				href="#about">{t("nav.about")}</a
			>
			<a
				class="nav-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface"
				href="#skills">{t("nav.skills")}</a
			>
			<a
				class="nav-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface"
				href="#projects">{t("nav.projects")}</a
			>
			<a
				class="px-8 py-2.5 border border-primary/30 text-primary text-[10px] uppercase tracking-[0.3em] font-semibold transition-all duration-500 hover:bg-primary hover:text-on-primary hover:border-primary active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface"
				href="#contact">{t("nav.contact")}</a
			>

			<!-- Language Switcher -->
			<div class="relative group/lang ml-4">
				<button
					class="flex items-center gap-2 text-[10px] uppercase tracking-[0.2em] text-on-surface-variant hover:text-primary transition-colors duration-300 font-semibold"
					aria-label={t("nav.language")}
					aria-haspopup="true"
					aria-expanded="false"
				>
					<span
						class="material-symbols-outlined text-sm opacity-60"
						aria-hidden="true"
					>
						{t("nav.language.icon")}
					</span>
					{languages[lang]}
				</button>
				<div
					class="absolute right-0 top-full pt-4 opacity-0 invisible group-hover/lang:opacity-100 group-hover/lang:visible transition-all duration-300"
				>
					<div
						class="bg-surface-container-high border border-white/5 p-2 shadow-2xl flex flex-col gap-1 min-w-[140px] backdrop-blur-3xl"
					>
						{
							Object.entries(languages).map(([l, label]) => (
								<a
									href={l === "en" ? "/" : `/${l}/`}
									class={`px-4 py-2 text-[10px] uppercase tracking-widest hover:bg-white/5 transition-colors ${lang === l ? "text-primary" : "text-on-surface-variant"}`}
								>
									{label}
								</a>
							))
						}
					</div>
				</div>
			</div>
		</div>

		<!-- Mobile Hamburger -->
		<button
			class="md:hidden p-2 -mr-2 text-on-surface focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary group"
			id="menu-toggle"
			aria-label="Open navigation menu"
			aria-expanded="false"
			aria-controls="mobile-menu"
		>
			<div class="w-6 h-5 relative flex flex-col justify-center items-center">
				<span class="hamburger-line absolute top-0 left-0 w-full h-0.5 bg-current transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-[.open]:top-1/2 group-[.open]:-translate-y-1/2 group-[.open]:rotate-45"></span>
				<span class="hamburger-line w-3/4 h-0.5 bg-current transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] group-[.open]:opacity-0 group-[.open]:w-0 ml-auto"></span>
				<span class="hamburger-line absolute bottom-0 left-0 w-full h-0.5 bg-current transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-[.open]:bottom-1/2 group-[.open]:translate-y-1/2 group-[.open]:-rotate-45"></span>
			</div>
		</button>
	</div>

	<!-- Mobile Menu -->
	<div
		class="mobile-menu md:hidden overflow-hidden"
		id="mobile-menu"
		role="region"
		aria-label="Mobile Navigation"
	>
		<div
			class="flex flex-col px-8 pb-6 pt-2 space-y-4 bg-surface/95 backdrop-blur-3xl border-b border-white/5"
		>
			<a
				class="text-on-surface-variant hover:text-on-surface transition-colors duration-500 serif-display tracking-tight text-base"
				href="#about">{t("nav.about")}</a
			>
			<a
				class="text-on-surface-variant hover:text-on-surface transition-colors duration-500 serif-display tracking-tight text-base"
				href="#skills">{t("nav.skills")}</a
			>
			<a
				class="text-on-surface-variant hover:text-on-surface transition-colors duration-500 serif-display tracking-tight text-base"
				href="#projects">{t("nav.projects")}</a
			>
			<a
				class="inline-block w-full px-6 py-2.5 bg-primary text-on-primary font-medium tracking-wide text-center transition-all duration-500 hover:bg-white rounded-none mt-1 text-[10px] uppercase"
				href="#contact">{t("nav.contact")}</a
			>

			<div class="flex gap-6 pt-3 border-t border-white/5">
				{
					Object.entries(languages).map(([l, label]) => (
						<a
							href={l === "en" ? "/" : `/${l}/`}
							class={`text-[9px] uppercase tracking-[0.2em] ${lang === l ? "text-primary font-bold" : "text-on-surface-variant opacity-60"}`}
						>
							{label}
						</a>
					))
				}
			</div>
		</div>
	</div>
</nav>

<style>
	.mobile-menu {
		display: grid;
		grid-template-rows: 0fr;
		opacity: 0;
		visibility: hidden;
		transition: 
			grid-template-rows 0.6s cubic-bezier(0.16, 1, 0.3, 1),
			opacity 0.4s ease,
			visibility 0.4s;
	}

	.mobile-menu.open {
		grid-template-rows: 1fr;
		opacity: 1;
		visibility: visible;
	}

	.mobile-menu > div {
		min-height: 0;
	}

	@media (min-width: 768px) {
		.mobile-menu {
			display: none;
		}
	}
</style>

<script>
	function initNav() {
		const nav = document.getElementById("main-nav");
		const navContainer = document.getElementById("nav-container");
		const menuToggle = document.getElementById("menu-toggle");
		const mobileMenu = document.getElementById("mobile-menu");

		if (!nav || !navContainer || !menuToggle || !mobileMenu) return;

		// Throttle scroll event for performance
		let ticking = false;
		window.addEventListener(
			"scroll",
			() => {
				if (!ticking) {
					window.requestAnimationFrame(() => {
						if (window.scrollY > 50) {
							nav.classList.add("scrolled");
							navContainer.classList.remove("py-6");
							navContainer.classList.add("py-4");
						} else {
							nav.classList.remove("scrolled");
							navContainer.classList.remove("py-4");
							navContainer.classList.add("py-6");
						}
						ticking = false;
					});
					ticking = true;
				}
			},
			{ passive: true },
		);

		// Mobile menu toggle with ARIA updates
		menuToggle.addEventListener("click", () => {
			const isOpen = mobileMenu.classList.toggle("open");
			menuToggle.classList.toggle("open", isOpen);
			menuToggle.setAttribute("aria-expanded", isOpen.toString());
			menuToggle.setAttribute(
				"aria-label",
				isOpen ? "Close navigation menu" : "Open navigation menu",
			);
		});

		// Close mobile menu on link click
		mobileMenu.querySelectorAll("a").forEach((link) => {
			link.addEventListener("click", () => {
				mobileMenu.classList.remove("open");
				menuToggle.classList.remove("open");
				menuToggle.setAttribute("aria-expanded", "false");
				menuToggle.setAttribute("aria-label", "Open navigation menu");
			});
		});
	}

	initNav();
	document.addEventListener("astro:after-swap", initNav);
</script>
