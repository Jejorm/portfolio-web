---

---

<div
	id="precision-cursor"
	class="fixed w-14 h-14 rounded-full border border-primary/20 pointer-events-none z-[10000] mix-blend-difference hidden lg:block will-change-[left,top]"
	style="view-transition-name: precision-cursor;"
>
	<div
		class="absolute inset-0 m-auto w-1 h-1 bg-primary rounded-full shadow-[0_0_15px_rgba(198,198,198,0.6)]"
	>
	</div>
	{/* Technical Crosshair Lines */}
	<div
		class="absolute -top-3 left-1/2 w-[1px] h-5 bg-primary/10 -translate-x-1/2"
	>
	</div>
	<div
		class="absolute -bottom-3 left-1/2 w-[1px] h-5 bg-primary/10 -translate-x-1/2"
	>
	</div>
	<div
		class="absolute top-1/2 -left-3 w-5 h-[1px] bg-primary/10 -translate-y-1/2"
	>
	</div>
	<div
		class="absolute top-1/2 -right-3 w-5 h-[1px] bg-primary/10 -translate-y-1/2"
	>
	</div>
</div>

<style>
	#precision-cursor {
		transform: translate(-50%, -50%) scale(1);
		transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1),
			background-color 0.4s ease,
			border-color 0.4s ease;
		opacity: 0;
	}

	#precision-cursor.visible {
		opacity: 1;
	}

	#precision-cursor.hovering {
		transform: translate(-50%, -50%) scale(1.8);
		background-color: rgba(198, 198, 198, 0.03);
		border-color: rgba(198, 198, 198, 0.6);
	}

	#precision-cursor.clicking {
		transform: translate(-50%, -50%) scale(0.7);
		border-color: rgba(255, 255, 255, 0.8);
	}
</style>

<script>
	// Declaración para extender el objeto window en TypeScript
	declare global {
		interface Window {
			__cursorX?: number;
			__cursorY?: number;
			__mouseX?: number;
			__mouseY?: number;
		}
	}

	let cursor: HTMLElement | null = null;
	let mouseX = window.__mouseX !== undefined ? window.__mouseX : -100;
	let mouseY = window.__mouseY !== undefined ? window.__mouseY : -100;
	let cursorX = window.__cursorX !== undefined ? window.__cursorX : mouseX;
	let cursorY = window.__cursorY !== undefined ? window.__cursorY : mouseY;
	const speed = 0.15;

	const moveCursor = () => {
		cursorX += (mouseX - cursorX) * speed;
		cursorY += (mouseY - cursorY) * speed;

		// Re-seleccionar el cursor por si fue reemplazado en la navegación
		if (!cursor) cursor = document.getElementById("precision-cursor");
		
		if (cursor) {
			cursor.style.left = `${cursorX}px`;
			cursor.style.top = `${cursorY}px`;
			// Persistir para la siguiente navegación
			window.__cursorX = cursorX;
			window.__cursorY = cursorY;

			// Asegurar visibilidad si ya hay movimiento previo
			if (window.__mouseX !== undefined && !cursor.classList.contains("visible")) {
				cursor.classList.add("visible");
			}
		}

		requestAnimationFrame(moveCursor);
	};

	window.addEventListener("mousemove", (e) => {
		mouseX = e.clientX;
		mouseY = e.clientY;
		window.__mouseX = mouseX;
		window.__mouseY = mouseY;
		
		if (!cursor) cursor = document.getElementById("precision-cursor");
		if (cursor && !cursor.classList.contains("visible")) {
			cursor.classList.add("visible");
		}
	});

	// Iniciar motor de movimiento
	requestAnimationFrame(moveCursor);

	const updateHoverState = () => {
		if (!cursor) cursor = document.getElementById("precision-cursor");
		const interactives = document.querySelectorAll(
			'a, button, [role="button"], .group, .group\\/lang',
		);

		interactives.forEach((el) => {
			el.addEventListener("mouseenter", () =>
				cursor?.classList.add("hovering"),
			);
			el.addEventListener("mouseleave", () =>
				cursor?.classList.remove("hovering"),
			);
		});
	};

	window.addEventListener("mousedown", () => {
		if (!cursor) cursor = document.getElementById("precision-cursor");
		cursor?.classList.add("clicking");
	});
	window.addEventListener("mouseup", () => {
		if (!cursor) cursor = document.getElementById("precision-cursor");
		cursor?.classList.remove("clicking");
	});

	// Reinicializar en cada navegación de Astro (incluyendo cambios de idioma)
	document.addEventListener("astro:page-load", () => {
		cursor = document.getElementById("precision-cursor");
		updateHoverState();
		
		// Si ya teníamos posición, forzar posición inicial inmediata
		if (window.__mouseX !== undefined && cursor) {
			cursor.classList.add("visible");
			cursor.style.left = `${window.__cursorX}px`;
			cursor.style.top = `${window.__cursorY}px`;
		}
	});

	// Inicializar primer estado
	updateHoverState();
</script>
