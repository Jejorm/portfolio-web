---

---

<section class="py-32 px-8 bg-surface-container reveal" id="contact">
	<div class="max-w-7xl mx-auto">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-24">
			<!-- Info -->
			<div>
				<span class="text-[10px] uppercase tracking-[0.4em] text-accent-blue"
					>Inquiry</span
				>
				<h2 class="serif-display text-6xl mt-4 mb-8">
					Let us begin a <br />
					<span class="italic text-accent-blue">new structure.</span>
				</h2>
				<div class="space-y-4">
					<p class="text-on-surface-variant font-body">
						For commissions, technical consulting, or speaking engagements.
					</p>
					<a
						class="block text-2xl serif-display text-accent-blue hover:text-white transition-colors duration-500"
						href="mailto:office@architect.dev"
					>
						office@architect.dev
					</a>
				</div>
			</div>

			<!-- Form -->
			<form class="space-y-12">
				<div class="relative">
					<label
						class="text-[10px] uppercase tracking-widest text-accent-blue absolute -top-6 left-0"
						for="contact-name"
					>
						01. Identity
					</label>
					<input
						id="contact-name"
						class="w-full bg-transparent border-b border-accent-blue/30 py-4 focus:outline-none focus:border-accent-blue transition-colors duration-500 text-on-surface placeholder:text-zinc-700"
						placeholder="Your Name"
						type="text"
					/>
				</div>

				<div class="relative">
					<label
						class="text-[10px] uppercase tracking-widest text-accent-blue absolute -top-6 left-0"
						for="contact-email"
					>
						02. Communication
					</label>
					<input
						id="contact-email"
						class="w-full bg-transparent border-b border-accent-blue/30 py-4 focus:outline-none focus:border-accent-blue transition-colors duration-500 text-on-surface placeholder:text-zinc-700"
						placeholder="Email Address"
						type="email"
					/>
				</div>

				<div class="relative">
					<label
						class="text-[10px] uppercase tracking-widest text-accent-blue absolute -top-6 left-0"
						for="contact-message"
					>
						03. Intent
					</label>
					<textarea
						id="contact-message"
						class="w-full bg-transparent border-b border-accent-blue/30 py-4 focus:outline-none focus:border-accent-blue transition-colors duration-500 text-on-surface placeholder:text-zinc-700 resize-none"
						placeholder="Brief Description"
						rows="4"></textarea>
				</div>

				<button
					type="submit"
					class="w-full py-6 bg-accent-blue text-white font-bold uppercase tracking-[0.2em] text-xs transition-all duration-500 hover:bg-accent-blue-deep active:scale-[0.98] shadow-lg hover:shadow-accent-blue/20 cursor-pointer"
				>
					Submit Inquiry
				</button>
			</form>
		</div>
	</div>
</section>
