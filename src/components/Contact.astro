---

---

<section class="py-32 px-8 bg-surface-container reveal" id="contact">
	<div class="max-w-7xl mx-auto">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-24">
			<!-- Info -->
			<div>
				<span class="text-[10px] uppercase tracking-[0.4em] text-primary"
					>Inquiry</span
				>
				<h2 class="serif-display text-6xl mt-4 mb-8 text-on-surface">
					Let us begin a <br />
					<span class="italic text-primary">new structure.</span>
				</h2>
				<div class="space-y-4">
					<p class="text-on-surface-variant font-body font-light">
						Available for senior engineering roles, technical consulting, or architectural reviews.
					</p>
					<a
						class="block text-2xl serif-display text-primary hover:text-white transition-colors duration-500 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface-container"
						href="mailto:hello@yourdomain.com"
					>
						hello@yourdomain.com
					</a>
				</div>
			</div>

			<!-- Form -->
			<form class="space-y-12">
				<div class="relative">
					<label
						class="text-[10px] uppercase tracking-widest text-primary absolute -top-6 left-0"
						for="contact-name"
					>
						01. Identity
					</label>
					<input
						id="contact-name"
						name="name"
						required
						autocomplete="name"
						class="w-full bg-transparent border-b border-white/20 py-4 focus:outline-none focus:border-primary transition-colors duration-500 text-on-surface placeholder:text-surface-bright focus-visible:ring-0"
						placeholder="Your Name"
						type="text"
					/>
				</div>

				<div class="relative">
					<label
						class="text-[10px] uppercase tracking-widest text-primary absolute -top-6 left-0"
						for="contact-email"
					>
						02. Communication
					</label>
					<input
						id="contact-email"
						name="email"
						required
						autocomplete="email"
						class="w-full bg-transparent border-b border-white/20 py-4 focus:outline-none focus:border-primary transition-colors duration-500 text-on-surface placeholder:text-surface-bright focus-visible:ring-0"
						placeholder="Email Address"
						type="email"
					/>
				</div>

				<div class="relative">
					<label
						class="text-[10px] uppercase tracking-widest text-primary absolute -top-6 left-0"
						for="contact-message"
					>
						03. Intent
					</label>
					<textarea
						id="contact-message"
						name="message"
						required
						class="w-full bg-transparent border-b border-white/20 py-4 focus:outline-none focus:border-primary transition-colors duration-500 text-on-surface placeholder:text-surface-bright resize-none focus-visible:ring-0"
						placeholder="Project Details or Inquiry"
						rows="4"></textarea>
				</div>

				<button
					type="submit"
					class="w-full py-6 bg-primary text-on-primary font-bold uppercase tracking-[0.2em] text-xs transition-all duration-500 hover:bg-white active:scale-[0.99] rounded-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-4 focus-visible:ring-offset-surface-container"
				>
					Submit Inquiry
				</button>
			</form>
		</div>
	</div>
</section>
