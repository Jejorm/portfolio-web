---

---

<section class="py-32 px-8 bg-surface-container reveal" id="contact">
	<div class="max-w-7xl mx-auto">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-24">
			<!-- Info -->
			<div>
				<span class="text-[10px] uppercase tracking-[0.4em] text-primary"
					>Inquiry</span
				>
				<h2 class="serif-display text-6xl mt-4 mb-8 text-on-surface">
					Let us begin a <br />
					<span class="italic text-primary">new structure.</span>
				</h2>
				<div class="space-y-4">
					<p class="text-on-surface-variant font-body font-light">
						Available for full-stack development, freelance projects, or joining
						a solid engineering team.
					</p>
					<a
						class="inline-block text-2xl serif-display text-primary hover:text-white transition-colors duration-500 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary focus-visible:ring-offset-8 focus-visible:ring-offset-surface-container"
						href="mailto:hello@yourdomain.com"
					>
						hello@yourdomain.com
					</a>
				</div>
			</div>

			<!-- Form -->
			<form
				class="space-y-12"
				action="https://formspree.io/f/meepgbyp"
				method="POST"
			>
				<div class="relative group">
					<label
						class="text-xs uppercase tracking-widest text-primary absolute -top-6 left-0 transition-opacity group-focus-within:opacity-100 opacity-70"
						for="contact-name"
					>
						01. Identity
					</label>
					<input
						id="contact-name"
						name="name"
						required
						aria-required="true"
						autocomplete="name"
						class="w-full bg-transparent border-b border-white/20 py-5 text-lg focus:outline-none focus:border-primary focus:bg-white/5 transition-all duration-500 text-on-surface placeholder:text-on-surface-variant/40 focus-visible:ring-0 px-4 -mx-4 rounded-t-sm"
						placeholder="e.g., John Doe"
						type="text"
					/>
				</div>

				<div class="relative group">
					<label
						class="text-xs uppercase tracking-widest text-primary absolute -top-6 left-0 transition-opacity group-focus-within:opacity-100 opacity-70"
						for="contact-email"
					>
						02. Communication
					</label>
					<input
						id="contact-email"
						name="email"
						required
						aria-required="true"
						autocomplete="email"
						class="w-full bg-transparent border-b border-white/20 py-5 text-lg focus:outline-none focus:border-primary focus:bg-white/5 transition-all duration-500 text-on-surface placeholder:text-on-surface-variant/40 focus-visible:ring-0 px-4 -mx-4 rounded-t-sm"
						placeholder="e.g., hello@company.com"
						type="email"
					/>
				</div>

				<div class="relative group">
					<label
						class="text-xs uppercase tracking-widest text-primary absolute -top-6 left-0 transition-opacity group-focus-within:opacity-100 opacity-70"
						for="contact-message"
					>
						03. Intent
					</label>
					<textarea
						id="contact-message"
						name="message"
						required
						aria-required="true"
						class="w-full bg-transparent border-b border-white/20 py-5 text-lg focus:outline-none focus:border-primary focus:bg-white/5 transition-all duration-500 text-on-surface placeholder:text-on-surface-variant/40 resize-none focus-visible:ring-0 px-4 -mx-4 rounded-t-sm min-h-[120px]"
						placeholder="Tell me about your project, timeline, and goals..."
						rows="4"></textarea>
				</div>

				<button
					type="submit"
					class="w-full py-6 mt-4 bg-primary text-on-primary font-bold uppercase tracking-[0.2em] text-sm transition-all duration-500 hover:bg-white active:scale-[0.99] rounded-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-4 focus-visible:ring-offset-surface-container cursor-pointer"
				>
					Submit Inquiry
				</button>
			</form>
		</div>
	</div>
</section>
